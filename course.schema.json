{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Course",
  "description": "One course as scraped from a Western timetable screenshot. Place files under src/data/courses/.",
  "type": "object",
  "required": ["code", "components"],
  "additionalProperties": false,
  "properties": {
    "code": { "type": "string", "description": "Course code, e.g. \"ECE 2238A\"" },
    "name": { "type": "string", "description": "Course title" },
    "term": { "type": "string", "description": "e.g. \"Fall\", \"Winter\"" },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "sections"],
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string", "description": "LEC | TUT | LAB | ..." },
          "sections": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["section"],
              "additionalProperties": false,
              "properties": {
                "section": { "type": "string", "description": "e.g. \"001\"" },
                "classNbr": { "type": "string" },
                "instructor": {
                  "type": "string",
                  "description": "Bundling key. Blank, \".\", \"TBA\" or \"Staff\" = wildcard (bundles with anyone)."
                },
                "campus": { "type": "string" },
                "deliveryType": { "type": "string" },
                "status": { "type": "string" },
                "waitlist": { "type": ["number", "string"] },
                "meetings": {
                  "type": "array",
                  "description": "Empty = async/TBA (never conflicts).",
                  "items": {
                    "type": "object",
                    "required": ["day", "start", "end"],
                    "additionalProperties": false,
                    "properties": {
                      "day": { "type": "string", "enum": ["Mo", "Tu", "We", "Th", "Fr", "Sa", "Su"] },
                      "start": { "type": "string", "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$" },
                      "end": { "type": "string", "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$" },
                      "location": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
